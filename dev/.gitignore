# Dependencies (never dev/node_modules at dev/ root — each app has its own .gitignore)
node_modules/

# Rust workspace
target/

# Logs / OS
*.log
.DS_Store
Thumbs.db

# Env (never commit secrets)
.env
.env.*

# Electron build output (each app also has local .gitignore)
apps/electron/dist/
apps/electron/build/tools/

# Local vault-root created by `electron:dev` (app home = this `dev/` folder)
.upriv/
workspace/
.upriv-root
.upriv-invalidated-*

# Temp
temp/
