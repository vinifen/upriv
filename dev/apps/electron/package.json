{
  "name": "upriv-electron",
  "private": true,
  "version": "0.1.0-beta",
  "description": "Upriv desktop shell (Electron)",
  "main": "dist/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "concurrently -k \"npm run dev --prefix ../desktop\" \"wait-on -t 30000 http-get://127.0.0.1:1420 && npm run build:main && electron . --dev --no-sandbox\"",
    "start": "npm run build:main && electron . --no-sandbox",
    "pack": "npm run build:main && electron-builder --dir",
    "dist": "npm run build:main && electron-builder"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "concurrently": "9.1.2",
    "electron": "34.5.8",
    "electron-builder": "25.1.8",
    "typescript": "5.7.3",
    "wait-on": "8.0.3"
  },
  "build": {
    "appId": "com.upriv.desktop",
    "productName": "Upriv",
    "icon": "build/icons/icon.png",
    "directories": {
      "output": "../../target/release/bundle/electron"
    },
    "files": [
      "dist/**/*",
      {
        "from": "../desktop/renderer-out",
        "to": "renderer",
        "filter": [
          "**/*"
        ]
      },
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../target/release/upriv-daemon",
        "to": "bin/upriv-daemon"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "executableArgs": [
        "--no-sandbox"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    }
  }
}
