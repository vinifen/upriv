{
  "name": "upriv-desktop",
  "private": true,
  "version": "0.1.0-beta",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "build": "tsc --noEmit && vite build --configLoader native",
    "build:electron": "node ./scripts/build-electron.mjs",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@upriv/shared": "file:../shared",
    "fflate": "^0.8.2",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "22.15.3",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.4.1",
    "autoprefixer": "10.4.21",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import-newlines": "^1.4.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "postcss": "8.4.49",
    "prettier": "^3.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.33.0",
    "vite": "6.3.5"
  }
}
