{
  "name": "upriv-dev",
  "private": true,
  "description": "Upriv development workspace (desktop + mobile + Tauri shell)",
  "scripts": {
    "dev": "npm run dev --prefix desktop",
    "build": "npm run build --prefix desktop",
    "tauri": "npm run tauri --prefix desktop",
    "tauri:dev": "npm run tauri --prefix desktop -- dev",
    "tauri:build": "npm run tauri --prefix desktop -- build",
    "mobile:start": "npm run start --prefix mobile",
    "mobile:android": "npm run android --prefix mobile",
    "mobile:typecheck": "npm run typecheck --prefix mobile"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
