{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Upriv",
  "version": "0.1.0",
  "identifier": "com.upriv.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix desktop",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build --prefix desktop",
    "frontendDist": "../desktop/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Upriv",
        "width": 960,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
